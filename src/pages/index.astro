---
import BaseLayout from '../layouts/BaseLayout.astro';
import Eyebrow from '../components/Eyebrow.astro';
import SearchBar from '../components/SearchBar.astro';
import HeroMesh from '../components/HeroMesh.astro';
import SectionHeader from '../components/SectionHeader.astro';
import EntryCard from '../components/EntryCard.astro';
import BrandReviewCard from '../components/BrandReviewCard.astro';

const stats = [
  { icon: 'flask', label: 'SUBSTANCES', value: '6+' },
  { icon: 'scale', label: 'LEGAL DATA', value: '190+ REGIONS' },
  { icon: 'history', label: 'UPDATED', value: 'JAN 21 2026' },
  { icon: 'file', label: 'REPORTS', value: '52,000+' },
];

const ICON_PATHS: Record<string, string> = {
  flask: '<path d="M9 3h6v4l5 9a2 2 0 0 1-2 3H6a2 2 0 0 1-2-3l5-9V3z"/><path d="M9 3h6"/>',
  scale: '<path d="m16 16 3-8 3 8a4 4 0 0 1-6 0Z"/><path d="m2 16 3-8 3 8a4 4 0 0 1-6 0Z"/><path d="M7 21h10"/><path d="M12 3v18"/><path d="M5 8h14"/>',
  history: '<path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M12 7v5l4 2"/>',
  file: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>',
};

const featured = [
  { category: 'CANNABINOID', risk: 'low' as const, title: 'Cannabis', blurb: 'A psychoactive drug from the Cannabis plant used primarily for medical or recreational purposes. The main psychoactive component is THC.' },
  { category: 'STIMULANT', risk: 'high' as const, title: 'Cocaine', blurb: 'A strong stimulant frequently used as a recreational drug. It is commonly snorted, inhaled as smoke, or dissolved and injected into a vein.' },
  { category: 'DISSOCIATIVE', risk: 'moderate' as const, title: 'Ketamine', blurb: 'A medication primarily used for starting and maintaining anesthesia. It induces a trance-like state while providing pain relief, sedation, and memory loss.', faded: true },
];

const classes = [
  { label: 'STIMULANTS', href: '/#browse' },
  { label: 'DEPRESSANTS', href: '/#browse' },
  { label: 'PSYCHEDELICS', href: '/#browse' },
  { label: 'DISSOCIATIVES', href: '/#browse' },
  { label: 'CANNABINOIDS', href: '/#browse' },
  { label: 'EMPATHOGENS', href: '/#browse' },
];

const sponsors = [
  { label: 'BOTOX.MIAMI', href: 'https://botox.miami' },
  { label: 'CERTAPET', href: 'https://certapet.com' },
];

const title = 'DrugText.org — The Illicit Substance Database';
const description = 'A comprehensive, non-judgmental, open-source archive of pharmacological data, legal status, and harm-reduction protocols for psychoactive substances and research peptides.';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'DrugText.org Database',
    description,
    url: 'https://www.drugtext.org/',
    isPartOf: { '@type': 'WebSite', name: 'DrugText.org', url: 'https://www.drugtext.org/' },
  },
];
---
<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <!-- HERO -->
  <section class="hero" id="search">
    <HeroMesh />
    <div class="dt-container hero__inner">
      <div class="hero__content">
        <Eyebrow>ARCHIVE_VERSION_2.0 // ACCESS_PUBLIC</Eyebrow>
        <h1 class="dt-hero">The Illicit Substance Database</h1>
        <p class="hero__lede">A comprehensive, non-judgmental archive of pharmacological data, legal status, and harm reduction protocols for controlled substances.</p>
        <div class="hero__search">
          <SearchBar placeholder="Search database (e.g., Cannabis)..." buttonLabel="SEARCH_ARCHIVE" />
        </div>
      </div>
    </div>
  </section>

  <!-- STAT BAR -->
  <section class="statbar" aria-label="Database statistics">
    <div class="dt-container statbar__inner">
      {stats.map((s) => (
        <div class="statbar__item">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="statbar__icon" aria-hidden="true" set:html={ICON_PATHS[s.icon]} />
          <div>
            <div class="statbar__label">{s.label}</div>
            <div class="statbar__value">{s.value}</div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- FEATURED ENTRIES -->
  <section class="dt-section" id="featured">
    <div class="dt-container">
      <SectionHeader title="FEATURED_ENTRIES" description="Frequently accessed pharmacological profiles and harm reduction data.">
        <a slot="action" href="#browse" class="sh__cta">BROWSE_BY_CLASS →</a>
      </SectionHeader>
      <div class="grid grid-3">
        {featured.map((f) => (
          <EntryCard category={f.category} risk={f.risk} title={f.title} blurb={f.blurb} faded={f.faded} />
        ))}
      </div>
    </div>
  </section>

  <!-- BROWSE BY CLASS -->
  <section class="dt-section dt-section--white" id="browse">
    <div class="dt-container">
      <h2 class="browse__title">BROWSE_BY_CLASS</h2>
      <div class="browse__grid">
        {classes.map((c, i) => (
          <a href={c.href} class="browse__tile" data-first={i === 0}>{c.label}</a>
        ))}
      </div>
    </div>
  </section>

  <!-- BRAND REVIEWS -->
  <section class="dt-section" id="brand-reviews">
    <div class="dt-container">
      <SectionHeader title="BRAND_REVIEWS" description="Independent assessments of substance brands. Lab verification, red flag screening, and honest editorial analysis." />
      <BrandReviewCard
        name="MYND Mushroom Chocolates"
        meta="Psilocybin · Mushroom Edibles"
        criticalFlags={2}
        warnings={3}
        score={null}
        summary={`California-based mushroom chocolate brand with multiple red flags identified including competing "official" websites and no verifiable lab testing.`}
        href="/brands/mynd-mushroom-chocolates"
      />
    </div>
  </section>

  <!-- SPONSORS -->
  <section class="dt-section-tight dt-section--sunken">
    <div class="dt-container sponsors__inner">
      <h2 class="sponsors__title">OUR_SPONSORS</h2>
      <div class="sponsors__row">
        {sponsors.map((s) => (
          <a href={s.href} rel="nofollow sponsored noopener" class="sponsors__chip">{s.label}</a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    background: var(--dt-bg);
    overflow: hidden;
  }
  .hero__inner {
    position: relative;
    padding-block: clamp(56px, 8vw, 88px);
  }
  .hero__content {
    max-width: 560px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .hero__content :global(.eyebrow) { align-self: flex-start; }
  .hero__lede {
    font-family: var(--dt-font-body);
    font-size: 18px;
    line-height: 1.6;
    color: var(--dt-text-body);
    margin: 0;
    max-width: 460px;
  }
  .hero__search { max-width: 460px; margin-top: 4px; }

  .statbar {
    background: var(--dt-bg-subtle);
    border-top: 1px solid var(--dt-border);
    border-bottom: 1px solid var(--dt-border);
  }
  .statbar__inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    padding-block: 20px;
  }
  .statbar__item { display: flex; align-items: center; gap: 14px; }
  .statbar__icon { color: var(--dt-blue-bright); flex: none; }
  .statbar__label {
    font-family: var(--dt-font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--dt-text-muted);
    margin-bottom: 3px;
  }
  .statbar__value {
    font-family: var(--dt-font-mono);
    font-weight: 700;
    font-size: 15px;
    color: var(--dt-ink);
  }

  .grid { display: grid; gap: 20px; }
  .grid-3 { grid-template-columns: repeat(3, 1fr); }

  .sh__cta {
    font-family: var(--dt-font-mono);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--dt-ink);
    text-decoration: none;
  }
  .sh__cta:hover { color: var(--dt-blue); }

  .browse__title {
    font-family: var(--dt-font-mono);
    font-weight: 700;
    font-size: 22px;
    text-transform: uppercase;
    color: var(--dt-ink);
    margin: 0 0 28px;
    text-align: center;
  }
  .browse__grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    border: 1px solid var(--dt-border);
    border-radius: 2px;
    background: var(--dt-surface);
  }
  .browse__tile {
    padding: 36px 12px;
    border-left: 1px solid var(--dt-border);
    font-family: var(--dt-font-mono);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--dt-ink);
    text-align: center;
    text-decoration: none;
    transition: background var(--dt-dur-fast) var(--dt-ease);
  }
  .browse__tile[data-first="true"] { border-left: 0; }
  .browse__tile:hover { background: var(--dt-bg-subtle); }

  .sponsors__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }
  .sponsors__title {
    font-family: var(--dt-font-mono);
    font-weight: 700;
    font-size: 16px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--dt-ink);
    margin: 0;
  }
  .sponsors__row { display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; }
  .sponsors__chip {
    font-family: var(--dt-font-mono);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.04em;
    color: var(--dt-ink);
    border: 1px solid var(--dt-border-strong);
    border-radius: 2px;
    padding: 16px 32px;
    background: #fff;
    text-decoration: none;
  }
  .sponsors__chip:hover { border-color: var(--dt-border-ink); }

  @media (max-width: 920px) {
    .grid-3 { grid-template-columns: 1fr 1fr; }
    .browse__grid { grid-template-columns: repeat(3, 1fr); }
    .browse__tile { border-top: 1px solid var(--dt-border); }
    .browse__tile:nth-child(-n+3) { border-top: 0; }
    .browse__tile:nth-child(3n+1) { border-left: 0; }
    .statbar__inner { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 620px) {
    .grid-3 { grid-template-columns: 1fr; }
    .browse__grid { grid-template-columns: 1fr 1fr; }
    .browse__tile:nth-child(3n+1) { border-left: 1px solid var(--dt-border); }
    .browse__tile:nth-child(2n+1) { border-left: 0; }
  }
</style>
