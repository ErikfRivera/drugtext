---
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---
<span class:list={['eyebrow', className]}>
  <slot />
</span>

<style>
  .eyebrow {
    display: inline-flex;
    align-items: center;
    font-family: var(--dt-font-mono);
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--dt-blue);
    border: 1px solid var(--dt-blue-border);
    padding: 6px 12px;
    border-radius: 2px;
    text-transform: uppercase;
    white-space: nowrap;
  }
</style>
